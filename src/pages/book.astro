---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book Appointment — SmileCare Dental Clinic Lahore"
  description="Book your appointment online at SmileCare in Gulberg, Lahore. Choose a convenient time slot using our live scheduler — open Monday to Saturday."
>

  <!-- ── HERO STRIP ─────────────────────────────────────────────── -->
  <section class="inner-hero relative overflow-hidden bg-gradient-to-br from-sky-50 via-blue-50 to-slate-50">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[540px] w-[540px] rounded-full bg-primary/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 -left-40 h-[400px] w-[400px] rounded-full bg-accent/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="anim-hero text-sm text-text-muted" style="animation-delay:0ms" aria-label="Breadcrumb">
        <a href="/" class="transition-colors hover:text-primary">Home</a>
        <span class="mx-2">/</span>
        <span class="font-medium text-text">Book Appointment</span>
      </nav>
      <h1 class="anim-hero mt-4 text-4xl font-extrabold tracking-tight text-text sm:text-5xl lg:text-6xl" style="animation-delay:100ms">
        Book Your <span class="text-primary">Appointment</span>
      </h1>
      <p class="anim-hero mt-5 max-w-xl text-lg leading-relaxed text-text-muted" style="animation-delay:200ms">
        Choose a time that works for you — the scheduler below shows live availability. We're open Monday to Saturday, 9 AM – 7 PM.
      </p>
    </div>
  </section>


  <!-- ── CALENDLY INLINE WIDGET ─────────────────────────────────── -->
  <section class="border-t border-border bg-white py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">

      <!-- ════════════════════════════════════════════════════════
           CALENDLY BOOKING WIDGET
           To change the Calendly link, update the data-url value below.
           Current URL: https://calendly.com/dawoodxxahmad/30min
           ════════════════════════════════════════════════════════ -->
      <div
        class="calendly-inline-widget overflow-hidden rounded-2xl shadow-lg"
        data-url="https://calendly.com/dawoodxxahmad/30min"
        style="min-width:320px;height:700px;"
      ></div>
      <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
      <!-- ════════════════════════════════════════════════════════ -->

    </div>
  </section>


  <!-- ── ALTERNATIVES STRIP ─────────────────────────────────────── -->
  <section class="border-t border-border py-16" style="background: linear-gradient(150deg, #f0f9ff 0%, #e0f2fe 55%, #f8fafc 100%);">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="reveal text-base text-text-muted" data-delay="0">Prefer to book by phone or have a question first?</p>
      <div class="reveal mt-5 flex flex-col items-center justify-center gap-3 sm:flex-row" data-delay="80">
        <a
          href="tel:+923001234567"
          class="inline-flex items-center gap-2 rounded-xl border border-border bg-white px-6 py-3 text-sm font-semibold text-text shadow-sm transition-all duration-200 hover:border-primary hover:text-primary hover:shadow-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
          </svg>
          Call +92 300 1234567
        </a>
        <a
          href="https://wa.me/923001234567"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border border-border bg-white px-6 py-3 text-sm font-semibold text-text shadow-sm transition-all duration-200 hover:border-emerald-400 hover:text-[#25D366] hover:shadow-md"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          WhatsApp Us
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-xl border border-border bg-white px-6 py-3 text-sm font-semibold text-text shadow-sm transition-all duration-200 hover:border-primary hover:text-primary hover:shadow-md"
        >
          Send a Message
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
