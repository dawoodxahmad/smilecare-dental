---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';

const categories = [
  {
    id: 'preventive',
    label: 'Preventive Care',
    tagline: 'Stop problems before they start',
    accent: 'text-sky-600',
    bg: 'bg-white',
    services: [
      {
        title: 'General Dentistry',
        desc: 'Comprehensive check-ups, professional cleanings, cavity fillings, and personalised preventive plans to maintain lifelong oral health for the whole family.',
        tags: ['Check-ups', 'Fillings', 'X-rays', 'Cleaning'],
        accent: 'bg-sky-50 text-sky-600',
        icon: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
      },
      {
        title: 'Kids Dentistry',
        desc: 'Gentle, anxiety-free paediatric check-ups, fluoride treatments, fissure sealants, and habit counselling in an environment children actually enjoy.',
        tags: ['Fluoride', 'Sealants', 'Habit advice', 'Fun environment'],
        accent: 'bg-pink-50 text-pink-600',
        icon: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z',
      },
    ],
  },
  {
    id: 'cosmetic',
    label: 'Cosmetic Dentistry',
    tagline: 'Enhance your smile\'s natural beauty',
    accent: 'text-amber-600',
    bg: 'bg-surface-alt/50',
    services: [
      {
        title: 'Teeth Whitening',
        desc: 'Professional in-chair whitening treatments and custom take-home tray kits for a brilliantly bright smile that lasts — up to 8 shades lighter in one session.',
        tags: ['In-chair', 'Take-home trays', 'Long-lasting', 'Safe & gentle'],
        accent: 'bg-amber-50 text-amber-600',
        icon: 'M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z',
      },
      {
        title: 'Braces & Aligners',
        desc: 'Traditional metal braces, discreet ceramic braces, and clear aligner systems for all ages. Straighten your teeth comfortably at any stage of life.',
        tags: ['Metal braces', 'Ceramic braces', 'Clear aligners', 'All ages'],
        accent: 'bg-violet-50 text-violet-600',
        icon: 'M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5',
      },
    ],
  },
  {
    id: 'restorative',
    label: 'Restorative Dentistry',
    tagline: 'Repair, rebuild, and renew',
    accent: 'text-emerald-600',
    bg: 'bg-white',
    services: [
      {
        title: 'Root Canal Treatment',
        desc: 'Pain-free endodontic therapy using rotary instruments and advanced local anaesthesia to remove infection, save the natural tooth, and eliminate discomfort for good.',
        tags: ['Painless', 'Tooth-saving', 'Same-day relief', 'Digital X-ray guided'],
        accent: 'bg-red-50 text-red-500',
        icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
      },
      {
        title: 'Dental Implants',
        desc: 'Titanium implant fixtures with natural-looking ceramic crowns for a permanent, fully functional tooth replacement that looks, feels, and bites like your own tooth.',
        tags: ['Permanent', 'Natural look', 'Bone-preserving', 'Single & multiple'],
        accent: 'bg-emerald-50 text-emerald-600',
        icon: 'M21.75 6.75a4.5 4.5 0 0 1-4.884 4.484c-1.076-.091-2.264.071-2.95.904l-7.152 8.684a2.548 2.548 0 1 1-3.586-3.585l8.684-7.152c.833-.686.995-1.874.904-2.95a4.5 4.5 0 0 1 6.336-4.486l-3.276 3.276a3.004 3.004 0 0 0 2.25 2.25l3.276-3.276c.256.565.398 1.192.398 1.852Z',
      },
      {
        title: 'Crowns & Bridges',
        desc: 'Precision-crafted full-coverage ceramic crowns and fixed bridges that restore badly damaged or missing teeth — fabricated in our on-site laboratory for a perfect fit.',
        tags: ['Ceramic crowns', 'Fixed bridges', 'On-site lab', 'Same-week fitting'],
        accent: 'bg-purple-50 text-purple-600',
        icon: 'M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z',
      },
    ],
  },
  {
    id: 'specialized',
    label: 'Specialized Care',
    tagline: 'Advanced treatment for complex needs',
    accent: 'text-orange-600',
    bg: 'bg-surface-alt/50',
    services: [
      {
        title: 'Gum Treatment',
        desc: 'Comprehensive periodontal care including deep-cleaning (scaling & root planing), gum disease diagnosis, and long-term maintenance plans to protect your gum health.',
        tags: ['Scaling & RPC', 'Gum disease', 'Periodontal care', 'Maintenance plans'],
        accent: 'bg-teal-50 text-teal-600',
        icon: 'M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
      },
      {
        title: 'Emergency Dental Care',
        desc: 'Same-day appointments for toothache, chipped or broken teeth, knocked-out teeth, lost fillings, and trauma. Call us — we will always do our best to see you immediately.',
        tags: ['Same-day', 'Toothache', 'Trauma', 'Broken teeth'],
        accent: 'bg-orange-50 text-orange-600',
        icon: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z',
      },
    ],
  },
];
---

<BaseLayout
  title="Our Services — SmileCare Dental Clinic Lahore"
  description="Explore SmileCare's full range of dental services in Lahore — from routine check-ups to dental implants, braces, whitening, root canal, and emergency care."
>

  <!-- ── HERO STRIP ─────────────────────────────────────────────── -->
  <PageHero
    crumb="Services"
    preTitle="Our"
    highlight="Services"
    description="Every treatment your family needs, under one roof — from routine prevention to advanced restoration."
  >
    <!-- Quick-jump pills -->
    <nav class="anim-hero mt-10 flex flex-wrap gap-2" style="animation-delay:300ms" aria-label="Jump to category">
      {categories.map(c => (
        <a href={`#${c.id}`} class="rounded-full border border-border bg-white px-4 py-1.5 text-sm font-medium text-text-muted transition-all hover:border-primary hover:text-primary">
          {c.label}
        </a>
      ))}
    </nav>
  </PageHero>


  <!-- ── CATEGORY SECTIONS ──────────────────────────────────────── -->
  {categories.map((cat, ci) => (
    <section id={cat.id} class={`border-t border-border py-28 ${cat.bg}`}>
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

        <!-- Category header -->
        <div class="reveal mb-16" data-delay="0">
          <div class="flex items-center gap-3">
            <div class="h-px flex-1 bg-border"></div>
            <span class={`text-xs font-bold uppercase tracking-widest ${cat.accent}`}>
              {String(ci + 1).padStart(2, '0')} — {cat.label}
            </span>
            <div class="h-px flex-1 bg-border"></div>
          </div>
          <p class="mt-3 text-center text-sm text-text-muted">{cat.tagline}</p>
        </div>

        <!-- Service cards -->
        <div class={`grid grid-cols-1 gap-8 ${cat.services.length === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3'}`}>
          {cat.services.map((s, si) => (
            <div
              class="reveal group flex flex-col rounded-2xl border border-border bg-white p-8 transition-all duration-300 hover:-translate-y-1.5 hover:border-transparent hover:shadow-xl hover:shadow-primary/10"
              data-delay={si * 100}
            >
              <!-- Icon -->
              <div class={`mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl ${s.accent}`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d={s.icon}/>
                </svg>
              </div>

              <h3 class="text-lg font-semibold text-text">{s.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">{s.desc}</p>

              <!-- Tags -->
              <div class="mt-5 flex flex-wrap gap-2">
                {s.tags.map(tag => (
                  <span class="rounded-full bg-bg px-3 py-1 text-xs font-medium text-text-muted border border-border">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- CTA -->
              <a
                href="/book"
                class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-primary opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:gap-2"
              >
                Book this treatment
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}


  <!-- ── CTA BAND ───────────────────────────────────────────────── -->
  <CtaBand
    title="Not Sure Which Treatment You Need?"
    description="Book a consultation and our team will guide you to the right solution — no pressure, no jargon."
    primaryLabel="Book a Consultation"
    secondaryLabel="Call Us"
  />

</BaseLayout>
