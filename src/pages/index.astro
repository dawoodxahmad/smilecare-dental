  <!-- ═══════════════════════════════════════════════════════════
       CLIENT SCRIPTS
       ═══════════════════════════════════════════════════════════ -->
  <script>
    // carouselTimer lives at module scope so we can cancel it when navigating back
    let carouselTimer: ReturnType<typeof setInterval> | undefined;

    document.addEventListener('astro:page-load', () => {
      /* ── Count-up ───────────────────────────────────────────────── */
      function runCountUp(el: HTMLElement) {
        const target  = parseFloat(el.dataset.countTo ?? '0');
        const suffix  = el.dataset.suffix ?? '';
        const decimal = el.dataset.decimal === 'true';
        const dur     = 2000;
        const t0      = performance.now();

        (function tick(now: number) {
          const progress = Math.min((now - t0) / dur, 1);
          const eased    = 1 - Math.pow(1 - progress, 3);
          el.textContent = (decimal
            ? (eased * target).toFixed(1)
            : Math.round(eased * target)
          ) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        })(t0);
      }

      const countIO = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            runCountUp(entry.target as HTMLElement);
            countIO.unobserve(entry.target);
          });
        },
        { threshold: 0.5 }
      );
      document.querySelectorAll<HTMLElement>('.count-up').forEach(el => countIO.observe(el));

      /* ── Testimonial carousel ───────────────────────────────────── */
      clearInterval(carouselTimer);

      const track = document.getElementById('testimonial-track') as HTMLElement | null;
      if (!track) return;

      const dots      = document.querySelectorAll<HTMLElement>('.testimonial-dot');
      const prevBtn   = document.getElementById('prev-btn')!;
      const nextBtn   = document.getElementById('next-btn')!;
      const container = document.getElementById('testimonial-container')!;
      const total     = dots.length;
      let   current   = 0;

      function goTo(index: number) {
        current = ((index % total) + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => {
          const active = i === current;
          d.classList.toggle('active', active);
          d.setAttribute('aria-selected', String(active));
        });
      }

      function play()  { carouselTimer = setInterval(() => goTo(current + 1), 5500); }
      function pause() { clearInterval(carouselTimer); }

      prevBtn.addEventListener('click', () => { pause(); goTo(current - 1); play(); });
      nextBtn.addEventListener('click', () => { pause(); goTo(current + 1); play(); });
      dots.forEach(d => {
        d.addEventListener('click', () => {
          pause();
          goTo(parseInt(d.dataset.index ?? '0', 10));
          play();
        });
      });

      container.addEventListener('mouseenter', pause);
      container.addEventListener('mouseleave', play);

      play();
    });
  </script>

