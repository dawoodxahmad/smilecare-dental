---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Arc from '../components/Arc.astro';
import SectionHeading from '../components/SectionHeading.astro';

const hours = [
  { days: 'Monday – Saturday', time: '9:00 AM – 7:00 PM' },
  { days: 'Sunday',            time: 'Closed'             },
];

const quickContact = [
  {
    label: 'Call Us',
    value: '+92 300 1234567',
    href: 'tel:+923001234567',
    hint: 'Mon – Sat, 9 AM – 7 PM',
    icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z',
    bg: 'bg-primary/5',
    accent: 'bg-primary',
    hover: 'hover:border-primary/40',
  },
  {
    label: 'WhatsApp',
    value: '+92 300 1234567',
    href: 'https://wa.me/923001234567',
    hint: 'Chat with us anytime',
    icon: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z',
    iconFill: true,
    bg: 'bg-emerald-50',
    accent: 'bg-[#25D366]',
    hover: 'hover:border-emerald-300',
  },
  {
    label: 'Email Us',
    value: 'hello@smilecare.pk',
    href: 'mailto:hello@smilecare.pk',
    hint: 'We reply within 24 hours',
    icon: 'M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75',
    bg: 'bg-violet-50',
    accent: 'bg-violet-500',
    hover: 'hover:border-violet-300',
  },
];

const treatments = [
  'General Dentistry', 'Teeth Whitening', 'Braces & Aligners',
  'Root Canal', 'Dental Implants', 'Kids Dentistry',
  'Crowns & Bridges', 'Gum Treatment', 'Emergency Care', 'Other / Not sure',
];
---

<BaseLayout
  title="Contact Us — SmileCare Dental Clinic Lahore"
  description="Book an appointment or get in touch with SmileCare in Gulberg, Lahore. Call, WhatsApp, email, or fill out our online form — we'd love to hear from you."
>

  <!-- ── HERO STRIP ─────────────────────────────────────────────── -->
  <PageHero
    crumb="Contact"
    preTitle="Contact"
    highlight="Us"
    description="We'd love to hear from you. Book an appointment, ask a question, or drop by — we're here for you Monday to Saturday."
  />


  <!-- ── MAP + CONTACT DETAILS ──────────────────────────────────── -->
  <section class="border-t border-border bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-16 lg:grid-cols-2">

        <!-- Map placeholder — replace this div with a Google Maps <iframe> when ready -->
        <!-- <iframe src="https://www.google.com/maps/embed?pb=..." width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe> -->
        <div class="reveal" data-delay="0">
          <div
            class="relative overflow-hidden rounded-2xl shadow-lg"
            style="background-color:#EFE8D9; background-image: linear-gradient(#DED2B4 1px, transparent 1px), linear-gradient(to right, #DED2B4 1px, transparent 1px); background-size: 40px 40px;"
          >
            <div class="flex aspect-video items-center justify-center p-8">
              <div class="text-center">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary shadow-lg shadow-primary/30">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
                  </svg>
                </div>
                <p class="mt-4 font-semibold text-text">123 Gulberg Main Boulevard</p>
                <p class="text-sm text-text-muted">Lahore, Pakistan</p>
                <a
                  href="https://maps.google.com/?q=Gulberg+Main+Boulevard+Lahore+Pakistan"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-1.5 rounded-lg border border-border bg-white px-4 py-2 text-sm font-medium text-text-muted transition-colors hover:border-primary hover:text-primary"
                >
                  Open in Google Maps
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                  </svg>
                </a>
                <p class="mt-3 text-xs text-slate-400">(Replace this block with an embedded Google Map)</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact details -->
        <div class="reveal" data-delay="150">
          <div class="inline-flex flex-col items-start gap-2">
            <span class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Reach Us</span>
            <Arc />
          </div>
          <h2 class="font-display mt-4 text-2xl font-semibold tracking-tight text-text sm:text-3xl">Find Us / Get in Touch</h2>

          <ul class="mt-8 space-y-5">
            <!-- Address -->
            <li class="flex items-start gap-4">
              <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
                </svg>
              </span>
              <div>
                <p class="text-sm font-semibold text-text">Address</p>
                <p class="mt-0.5 text-sm leading-relaxed text-text-muted">123 Gulberg Main Boulevard<br />Lahore, Pakistan</p>
              </div>
            </li>

            <!-- Phone -->
            <li class="flex items-center gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
                </svg>
              </span>
              <div>
                <p class="text-sm font-semibold text-text">Phone</p>
                <a href="tel:+923001234567" class="mt-0.5 text-sm text-text-muted transition-colors hover:text-primary">+92 300 1234567</a>
              </div>
            </li>

            <!-- WhatsApp -->
            <li class="flex items-center gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-50">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                </svg>
              </span>
              <div>
                <p class="text-sm font-semibold text-text">WhatsApp</p>
                <a href="https://wa.me/923001234567" target="_blank" rel="noopener noreferrer" class="mt-0.5 text-sm text-text-muted transition-colors hover:text-[#25D366]">+92 300 1234567</a>
              </div>
            </li>

            <!-- Email -->
            <li class="flex items-center gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
                </svg>
              </span>
              <div>
                <p class="text-sm font-semibold text-text">Email</p>
                <a href="mailto:hello@smilecare.pk" class="mt-0.5 text-sm text-text-muted transition-colors hover:text-primary">hello@smilecare.pk</a>
              </div>
            </li>
          </ul>

          <!-- Hours -->
          <div class="mt-8 rounded-2xl border border-border bg-bg p-5">
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-widest text-text">Clinic Hours</h3>
            <ul class="space-y-2">
              {hours.map(({ days, time }) => (
                <li class="flex items-center justify-between text-sm">
                  <span class="text-text-muted">{days}</span>
                  <span class={`font-medium ${time === 'Closed' ? 'text-red-500' : 'text-text'}`}>{time}</span>
                </li>
              ))}
            </ul>
            <div class="mt-4 rounded-xl border border-primary/20 bg-primary/5 px-4 py-3">
              <p class="text-xs leading-relaxed text-primary">
                <span class="font-semibold">Dental emergency?</span> Call anytime — we will always try to see you the same day.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ── QUICK CONTACT CARDS ────────────────────────────────────── -->
  <section class="border-t border-border py-20" style="background: linear-gradient(150deg, #F7F0DD 0%, #F0E1BF 55%, #FBF7EF 100%);">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
        {quickContact.map((c, i) => (
          <a
            href={c.href}
            target={c.href.startsWith('http') ? '_blank' : undefined}
            rel={c.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class={`reveal group flex items-center gap-5 rounded-2xl border border-border bg-white p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg ${c.hover}`}
            data-delay={i * 100}
          >
            <div class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-xl text-white ${c.accent}`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill={c.iconFill ? 'currentColor' : 'none'} stroke={c.iconFill ? 'none' : 'currentColor'} stroke-width={c.iconFill ? '0' : '2'}>
                <path stroke-linecap="round" stroke-linejoin="round" d={c.icon}/>
              </svg>
            </div>
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase tracking-widest text-text-muted">{c.label}</p>
              <p class="mt-0.5 truncate text-sm font-medium text-text">{c.value}</p>
              <p class="text-xs text-text-muted">{c.hint}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ── BOOKING FORM ───────────────────────────────────────────── -->
  <section id="book" class="border-t border-border bg-white py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">

      <SectionHeading
        eyebrow="Book Online"
        title="Request an Appointment"
        description="Fill in the form and we will call you back within a few hours to confirm your slot."
        class="mb-14"
      />

      <div class="reveal rounded-2xl border border-border bg-bg p-10 sm:p-12" data-delay="100">
        <form id="contact-form" novalidate>
          <!-- ════════════════════════════════════════════════════
               WEB3FORMS CONFIGURATION
               Access key is already set below. If you ever
               regenerate it, replace the value= attribute.
               Current key: 6dbde00d-dc08-4e35-87e3-e3ce0afa7ed4
               ════════════════════════════════════════════════════ -->
          <input type="hidden" name="access_key" value="6dbde00d-dc08-4e35-87e3-e3ce0afa7ed4" />
          <input type="hidden" name="subject"    value="New Appointment Request — SmileCare" />
          <input type="hidden" name="from_name"  value="SmileCare Website" />
          <!-- ════════════════════════════════════════════════════ -->

          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">

            <!-- Name -->
            <div>
              <label for="f-name" class="block text-sm font-medium text-text">Full Name <span class="text-red-500" aria-hidden="true">*</span></label>
              <input
                id="f-name" name="name" type="text" required autocomplete="name"
                placeholder="Your full name"
                class="mt-1.5 w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-text placeholder:text-text-muted/50 transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="f-email" class="block text-sm font-medium text-text">Email Address <span class="text-red-500" aria-hidden="true">*</span></label>
              <input
                id="f-email" name="email" type="email" required autocomplete="email"
                placeholder="you@example.com"
                class="mt-1.5 w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-text placeholder:text-text-muted/50 transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="f-phone" class="block text-sm font-medium text-text">Phone / WhatsApp <span class="text-red-500" aria-hidden="true">*</span></label>
              <input
                id="f-phone" name="phone" type="tel" required autocomplete="tel"
                placeholder="+92 300 0000000"
                class="mt-1.5 w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-text placeholder:text-text-muted/50 transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              />
            </div>

            <!-- Treatment interest -->
            <div>
              <label for="f-treatment" class="block text-sm font-medium text-text">Treatment Interest <span class="text-text-muted font-normal">(optional)</span></label>
              <select
                id="f-treatment" name="treatment"
                class="mt-1.5 w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              >
                <option value="">— Select a treatment —</option>
                {treatments.map(t => <option value={t}>{t}</option>)}
              </select>
            </div>

          </div>

          <!-- Message -->
          <div class="mt-6">
            <label for="f-message" class="block text-sm font-medium text-text">Message</label>
            <textarea
              id="f-message" name="message" rows="5"
              placeholder="Tell us a bit about your concern or when you'd like to come in…"
              class="mt-1.5 w-full resize-none rounded-xl border border-border bg-white px-4 py-3 text-sm text-text placeholder:text-text-muted/50 transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            ></textarea>
          </div>

          <!-- Submit -->
          <div class="mt-8">
            <button
              id="form-submit"
              type="submit"
              class="w-full rounded-xl bg-primary px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary/25 transition-all duration-200 hover:bg-primary-dark hover:shadow-xl active:scale-95 disabled:cursor-not-allowed disabled:opacity-70"
            >
              Send Message &amp; Request Appointment
            </button>
            <p class="mt-3 text-center text-xs text-text-muted">
              We typically respond within a few hours during clinic hours. For urgent care, please call directly.
            </p>
          </div>

          <!-- Status message — shown on success or error -->
          <div id="form-status" hidden></div>
        </form>
      </div>
    </div>
  </section>


  <script>
    document.addEventListener('astro:page-load', () => {
      /* ── Contact form → Web3Forms ───────────────────────────────── */
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      if (!form) return;

      const submit   = document.getElementById('form-submit')  as HTMLButtonElement;
      const statusEl = document.getElementById('form-status')  as HTMLDivElement;

      const ORIGINAL_LABEL = 'Send Message & Request Appointment';

      function showStatus(type: 'success' | 'error', msg: string) {
        statusEl.textContent = msg;
        statusEl.className = [
          'mt-5 rounded-xl border px-5 py-4 text-sm font-medium text-center',
          type === 'success'
            ? 'border-emerald-200 bg-emerald-50 text-emerald-700'
            : 'border-red-200 bg-red-50 text-red-700',
        ].join(' ');
        statusEl.hidden = false;
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        statusEl.hidden = true;

        const name  = (form.elements.namedItem('name')  as HTMLInputElement).value.trim();
        const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
        const phone = (form.elements.namedItem('phone') as HTMLInputElement).value.trim();

        if (!name || !email || !phone) {
          showStatus('error', 'Please fill in your name, email, and phone number.');
          return;
        }

        submit.disabled    = true;
        submit.textContent = 'Sending…';

        try {
          const res  = await fetch('https://api.web3forms.com/submit', {
            method:  'POST',
            headers: { Accept: 'application/json' },
            body:    new FormData(form),
          });
          const json = await res.json();

          if (json.success) {
            showStatus('success', "✓ Your request has been sent! We'll call you back within a few hours to confirm your slot.");
            form.reset();
            submit.textContent = 'Sent!';
            setTimeout(() => {
              submit.disabled    = false;
              submit.textContent = ORIGINAL_LABEL;
            }, 4000);
          } else {
            throw new Error(json.message ?? 'Submission failed');
          }
        } catch {
          submit.disabled    = false;
          submit.textContent = ORIGINAL_LABEL;
          showStatus('error', 'Something went wrong. Please try again or call us at +92 300 1234567.');
        }
      });
    });
  </script>

</BaseLayout>
