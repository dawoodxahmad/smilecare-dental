---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title       = 'SmileCare Dental Clinic',
  description = 'Modern, compassionate dental care for your whole family. Book your appointment today.',
  ogImage     = '/og-image.png',
} = Astro.props;

const siteURL      = Astro.site ?? 'https://smilecare.clinic';
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const ogImageURL   = new URL(ogImage, siteURL);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type':    ['Dentist', 'LocalBusiness'],
  name:        'SmileCare Dental Clinic',
  url:         siteURL.toString(),
  logo:        new URL('/favicon.svg', siteURL).toString(),
  description: 'Modern, compassionate dental care for your whole family in Gulberg, Lahore.',
  telephone:   '+92-300-1234567',
  email:       'hello@smilecare.pk',
  address: {
    '@type':         'PostalAddress',
    streetAddress:    '123 Gulberg Main Boulevard',
    addressLocality:  'Lahore',
    addressRegion:    'Punjab',
    postalCode:       '54660',
    addressCountry:   'PK',
  },
  geo: {
    '@type':   'GeoCoordinates',
    latitude:  '31.5204',
    longitude: '74.3587',
  },
  openingHoursSpecification: [
    {
      '@type':     'OpeningHoursSpecification',
      dayOfWeek:   ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens:       '09:00',
      closes:      '19:00',
    },
  ],
  priceRange: '₨₨',
  areaServed: { '@type': 'City', name: 'Lahore' },
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="SmileCare Dental Clinic" />
    <meta property="og:locale"      content="en_PK" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageURL} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageURL} />

    <!-- Theme color -->
    <meta name="theme-color" content="#0F6B52" />

    <!-- Favicon slot — drop your own icons into /public -->
    <slot name="favicon">
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    </slot>

    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{title}</title>

    <!-- LocalBusiness / Dentist structured data for Google -->
    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Smooth page-to-page transitions (Astro ClientRouter / View Transitions) -->
    <ClientRouter />

    <!-- Extra <head> content (analytics, etc.) -->
    <slot name="head" />
  </head>

  <body>
    <!-- transition:persist keeps the navbar DOM stable across navigations
         so the solid/transparent state never flickers between pages -->
    <Navbar transition:persist />
    <slot />
    <Footer />

    <!-- ── Floating WhatsApp button ──────────────────────────────── -->
    <a
      href="https://wa.me/923010522678"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Chat with SmileCare on WhatsApp"
      transition:persist
      class="fixed bottom-6 right-4 z-40 flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] shadow-lg shadow-[#25D366]/40 transition-all duration-200 hover:scale-110 hover:shadow-xl hover:shadow-[#25D366]/50 sm:bottom-8 sm:right-6"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
    </a>

    <!-- ── Centralized scroll-reveal ──────────────────────────────
         Fires on every page load (initial + View Transitions navigations).
         Individual pages no longer need their own reveal script. -->
    <script>
      function initReveal() {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const delay = Math.min(parseInt(el.dataset.delay ?? '0', 10), 250);
              el.style.willChange = 'transform, opacity';
              el.style.transitionDelay = delay + 'ms';
              el.classList.add('visible');
              el.addEventListener('transitionend', () => { el.style.willChange = 'auto'; }, { once: true });
              io.unobserve(el);
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach(el => io.observe(el));
      }
      document.addEventListener('astro:page-load', () => {
        // Reset any stale will-change from a previous page before observing
        document.querySelectorAll<HTMLElement>('.reveal').forEach(el => {
          el.style.willChange = '';
        });
        initReveal();
      });
    </script>
  </body>
</html>
