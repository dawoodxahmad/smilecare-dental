---
const navLinks = [
  { href: '/',         label: 'Home' },
  { href: '/about',    label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/gallery',  label: 'Gallery' },
  { href: '/contact',  label: 'Contact' },
];
---

<header
  id="navbar"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
>
  <!-- Main bar -->
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">

    <!-- Logo -->
    <a href="/" class="flex items-baseline gap-0.5 select-none" aria-label="SmileCare home">
      <span class="text-2xl font-extrabold tracking-tight text-primary">Smile</span>
      <span class="text-2xl font-extrabold tracking-tight text-text">Care</span>
    </a>

    <!-- Desktop navigation -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="group relative px-3 py-2 text-sm font-medium text-text transition-colors duration-200 hover:text-primary"
        >
          {label}
          <!-- animated underline -->
          <span
            class="absolute bottom-1 left-3 right-3 h-0.5 origin-left scale-x-0 rounded-full bg-primary
                   transition-transform duration-200 group-hover:scale-x-100"
          ></span>
        </a>
      ))}

      <a
        href="/book"
        class="ml-4 rounded-lg bg-primary px-5 py-2 text-sm font-semibold text-white shadow-sm
               transition-all duration-200 hover:bg-primary-dark hover:shadow-md active:scale-95"
      >
        Book Appointment
      </a>
    </nav>

    <!-- Hamburger (mobile) -->
    <button
      id="hamburger-btn"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-md text-text
             transition-colors hover:bg-slate-100 md:hidden"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <!-- Menu icon -->
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none"
           viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <!-- Close icon -->
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none"
           viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer (slide-in via max-height transition) -->
  <div
    id="mobile-drawer"
    class="overflow-hidden md:hidden"
    style="max-height: 0; transition: max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1);"
    aria-hidden="true"
  >
    <nav
      class="border-t border-slate-100 bg-white px-4 pb-5 pt-2"
      aria-label="Mobile navigation"
    >
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="block rounded-lg px-4 py-3 text-sm font-medium text-text
                 transition-colors duration-150 hover:bg-primary/10 hover:text-primary"
        >
          {label}
        </a>
      ))}
      <a
        href="/book"
        class="mt-3 block rounded-lg bg-primary px-4 py-3 text-center text-sm font-semibold
               text-white transition-colors duration-150 hover:bg-primary-dark"
      >
        Book Appointment
      </a>
    </nav>
  </div>
</header>

<script>
  let isOpen = false;

  /* ── Navbar background (re-evaluated on scroll and every navigation) ── */
  function syncNavbarBg() {
    const navbar = document.getElementById('navbar') as HTMLElement | null;
    if (!navbar) return;
    const solid = window.location.pathname !== '/' || window.scrollY > 20 || isOpen;
    navbar.classList.toggle('bg-white',  solid);
    navbar.classList.toggle('shadow-md', solid);
  }

  /* ── Close drawer (safe to call when already closed) ─────────── */
  function closeMenu() {
    if (!isOpen) return;
    const btn       = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
    const drawer    = document.getElementById('mobile-drawer') as HTMLElement | null;
    const iconMenu  = document.getElementById('icon-menu')     as Element | null;
    const iconClose = document.getElementById('icon-close')    as Element | null;
    if (!btn || !drawer || !iconMenu || !iconClose) return;
    isOpen = false;
    btn.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    drawer.style.maxHeight = '0';
    iconMenu.classList.remove('hidden');
    iconClose.classList.add('hidden');
    syncNavbarBg();
  }

  /* ── Wire up interactive behaviour ───────────────────────────── */
  // Called on every astro:page-load so the hamburger keeps working
  // after View Transitions navigations.  Uses .onclick instead of
  // addEventListener so repeated calls never accumulate duplicate handlers.
  function initMenu() {
    const btn       = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
    const drawer    = document.getElementById('mobile-drawer') as HTMLElement | null;
    const iconMenu  = document.getElementById('icon-menu')     as Element | null;
    const iconClose = document.getElementById('icon-close')    as Element | null;
    if (!btn || !drawer || !iconMenu || !iconClose) return;

    // Always start each page with the drawer fully closed
    isOpen = false;
    drawer.style.maxHeight = '0';
    btn.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    iconMenu.classList.remove('hidden');
    iconClose.classList.add('hidden');

    btn.onclick = () => {
      isOpen = !isOpen;
      btn.setAttribute('aria-expanded', String(isOpen));
      drawer.setAttribute('aria-hidden', String(!isOpen));
      if (isOpen) {
        drawer.style.maxHeight = drawer.scrollHeight + 'px';
        iconMenu.classList.add('hidden');
        iconClose.classList.remove('hidden');
      } else {
        drawer.style.maxHeight = '0';
        iconMenu.classList.remove('hidden');
        iconClose.classList.add('hidden');
      }
      syncNavbarBg();
    };

    // Auto-close when any drawer link is tapped
    drawer.querySelectorAll('a').forEach(link => {
      (link as HTMLAnchorElement).onclick = () => closeMenu();
    });

    syncNavbarBg();
  }

  /* ── Global hooks (registered once at module init) ───────────── */
  window.addEventListener('scroll', syncNavbarBg, { passive: true });
  // Close before the View Transition swap animation so the drawer
  // does not stay open over the incoming page
  document.addEventListener('astro:before-swap', closeMenu);
  // Re-initialize on every page (initial load + every navigation)
  document.addEventListener('astro:page-load', initMenu);
</script>
