---
const quickLinks = [
  { href: '/',                label: 'Home' },
  { href: '/about',           label: 'About Us' },
  { href: '/services',        label: 'Our Services' },
  { href: '/gallery',         label: 'Gallery' },
  { href: '/contact',         label: 'Contact' },
  { href: '/book',            label: 'Book Appointment' },
];

const hours = [
  { days: 'Mon – Sat', time: '9:00 AM – 7:00 PM' },
  { days: 'Sunday',    time: 'Closed' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-text text-slate-400">

  <!-- Main grid -->
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">

      <!-- ── Brand column ──────────────────────────────────── -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-baseline gap-0.5" aria-label="SmileCare home">
          <span class="font-display text-3xl font-semibold tracking-tight text-primary-light">Smile</span>
          <span class="font-display text-3xl font-semibold tracking-tight text-white">Care</span>
        </a>

        <p class="mt-2 text-sm font-medium italic text-slate-400">
          Your smile, our priority.
        </p>

        <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-500">
          Providing modern, compassionate dental care to families across Lahore
          since 2010.
        </p>

        <!-- Social icons -->
        <div class="mt-6 flex gap-3">
          <!-- Facebook -->
          <a
            href="https://facebook.com/smilecare"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="SmileCare on Facebook"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-700
                   text-slate-300 transition-colors duration-200 hover:bg-primary hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>

          <!-- Instagram -->
          <a
            href="https://instagram.com/smilecare"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="SmileCare on Instagram"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-700
                   text-slate-300 transition-colors duration-200 hover:bg-primary hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/923001234567"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Chat with SmileCare on WhatsApp"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-700
                   text-slate-300 transition-colors duration-200 hover:bg-[#25D366] hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- ── Contact column ──────────────────────────────────── -->
      <div>
        <h3 class="mb-5 text-sm font-semibold uppercase tracking-widest text-white">
          Contact Us
        </h3>
        <ul class="space-y-4 text-sm">

          <!-- Address -->
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 shrink-0 text-primary" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="leading-relaxed">
              123 Gulberg Main Boulevard<br />Lahore, Pakistan
            </span>
          </li>

          <!-- Phone -->
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-primary" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:+923001234567"
               class="transition-colors hover:text-primary">
              +92 300 1234567
            </a>
          </li>

          <!-- WhatsApp -->
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            <a href="https://wa.me/923001234567"
               target="_blank"
               rel="noopener noreferrer"
               class="transition-colors hover:text-[#25D366]">
              +92 300 1234567
            </a>
          </li>

          <!-- Email -->
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-primary" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:hello@smilecare.pk"
               class="transition-colors hover:text-primary">
              hello@smilecare.pk
            </a>
          </li>
        </ul>
      </div>

      <!-- ── Hours column ─────────────────────────────────────── -->
      <div>
        <h3 class="mb-5 text-sm font-semibold uppercase tracking-widest text-white">
          Clinic Hours
        </h3>
        <ul class="space-y-3 text-sm">
          {hours.map(({ days, time }) => (
            <li class="flex items-start justify-between gap-4">
              <span class="text-slate-400">{days}</span>
              <span class={`font-medium ${time === 'Closed' ? 'text-red-400' : 'text-slate-200'}`}>
                {time}
              </span>
            </li>
          ))}
        </ul>

        <!-- Emergency note -->
        <div class="mt-6 rounded-lg border border-primary/20 bg-primary/10 px-4 py-3">
          <p class="text-xs leading-relaxed text-primary-light">
            <span class="font-semibold">Dental emergency?</span><br />
            Call us anytime — we'll do our best to see you same day.
          </p>
        </div>
      </div>

      <!-- ── Quick links column ───────────────────────────────── -->
      <div>
        <h3 class="mb-5 text-sm font-semibold uppercase tracking-widest text-white">
          Quick Links
        </h3>
        <ul class="space-y-2 text-sm">
          {quickLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="group flex items-center gap-2 transition-colors duration-150 hover:text-primary"
              >
                <span class="h-px w-4 bg-slate-600 transition-all duration-150 group-hover:w-5 group-hover:bg-primary"></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-slate-700">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-2
                px-4 py-5 text-xs text-slate-500 sm:flex-row sm:px-6 lg:px-8">
      <span>&copy; {currentYear} SmileCare Dental Clinic. All rights reserved.</span>
      <span>Crafted with care in Lahore, Pakistan 🇵🇰</span>
    </div>
  </div>

</footer>
