---
import Arc from './Arc.astro';

interface Props {
  title: string;
  description: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const {
  title,
  description,
  primaryLabel = 'Book Appointment',
  primaryHref = '/book',
  secondaryLabel = 'Call Now',
  secondaryHref = 'tel:+923001234567',
} = Astro.props;
---

<section class="relative overflow-hidden bg-primary py-24">
  <div class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full bg-white/10 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-32 -left-32 h-96 w-96 rounded-full bg-accent/20 blur-3xl"></div>
  <Arc variant="hero" class="pointer-events-none absolute -bottom-4 left-1/2 h-auto w-[900px] max-w-none -translate-x-1/2 text-white opacity-20" />

  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <div class="reveal" data-delay="0">
      <h2 class="font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-5xl">
        {title}
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-white/80">{description}</p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={primaryHref}
          class="inline-flex items-center gap-2 rounded-xl bg-white px-8 py-4 text-base font-semibold text-primary shadow-xl transition-all duration-200 hover:bg-surface-alt hover:shadow-2xl active:scale-95"
        >
          {primaryLabel}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
        <a
          href={secondaryHref}
          class="inline-flex items-center gap-2 rounded-xl border-2 border-white/40 px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:border-white hover:bg-white/10 active:scale-95"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
          </svg>
          {secondaryLabel}
        </a>
      </div>
    </div>
  </div>
</section>
